# Copy to .env and fill in. Get your key from https://console.sakana.ai/get-started
SAKANA_API_KEY=

# Optional. Defaults to https://api.sakana.ai/v1
# NOTE: the base URL is not published on a public page — copy the exact value
# from your console dashboard if it differs from the default.
SAKANA_BASE_URL=https://api.sakana.ai/v1

# Optional. "fugu" (fast / low-latency) or "fugu-ultra" (max quality). Default: fugu-ultra
FUGU_MODEL=fugu-ultra
